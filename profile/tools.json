{
  "$schema": "https://raw.githubusercontent.com/m-dev-tools/.github/main/profile/tools.schema.json",
  "description": "Machine-readable catalog for the m-dev-tools GitHub organization. Summary-only: each tools.* entry carries identification + pointer URLs into the source repo's dist/repo.meta.json.exposes.* payloads. Intent routing lives in profile/task_index.json (Phase-1 Track B's build-catalog.py merges them at build time). No inlined facts (no subcommand lists, no module dictionaries, no rule arrays) — those drift; the pointer URLs don't.",
  "discovery_protocol": {
    "_comment": "How an AI agent should consume this catalog when given a fresh user request.",
    "step_1_read": [
      "llms.txt — human-sized AI entrypoint and priority reading order",
      "tools.json — this machine-readable org catalog",
      "task_index.json — hand-curated intent → typed-ID routing",
      "tools.schema.json + task_index.schema.json — validation contracts"
    ],
    "step_2_match_intent": "Map the user's plain-English request to one or more task_index categories[*].* keys. Prefer exact keys first, then fuzzy keyword match against each `intent` string.",
    "step_3_resolve_tools": "For each matched task, follow `primary` and `see_also` typed-IDs into the `tools` map. The kind prefix (`tool:` / `cmd:` / `module:` / `data:`) tells you what surface to expect. Follow the *_url pointers for machine-readable payloads.",
    "step_4_load_local_context": "Before changing a repo, read that repo's AGENTS.md (canonical) — repo-local instructions override org-level generalities.",
    "step_5_load_manifests": "For symbol-level work, fetch the relevant *_url payload. Use m-stdlib's manifest_url for STD* APIs; m-standard's *_url tables for language semantics; m-cli's commands_url / lint_rules_url / fmt_rules_url for tooling capabilities.",
    "step_6_compose_workflow": "Use `workflow.tdd_inner_loop` for new application work: scaffold, write failing test, implement, run test, fmt, lint, coverage, CI.",
    "step_7_verify": "Run the nearest available toolchain checks (`m test`, `m fmt --check`, `m lint`, `m coverage`, `m doctor`) before declaring completion.",
    "step_8_do_not_invent": "If a requested STD* API, m-cli command, lint rule, or language token is absent from the relevant *_url payload, do not fabricate it. State the gap and route the addition to the owning repo."
  },
  "kind": "m-dev-tools.org-catalog",
  "org": {
    "first_principles": [
      "m-stdlib has architectural priority over m-cli — when both projects need a utility, it lands in m-stdlib first.",
      "Source-level tools (m fmt, m lint) are engine-neutral; runtime tools (m test, m coverage) are YottaDB-targeted.",
      "Every module ships with a vendored conformance corpus tied to the relevant RFC or NIST publication.",
      "m-cli's CLI ergonomics deliberately mirror Go (`go fmt`/`test`/`vet`) and Rust (`cargo fmt`/`test`/`clippy`) — see m-tools/docs/m-tool-gap-analysis.md for the gap analysis that drove the design."
    ],
    "license_default": "AGPL-3.0",
    "license_exceptions": {
