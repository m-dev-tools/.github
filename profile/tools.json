  "workflow": {
    "minimal_application_recipe": {
      "description": "Smallest realistic project: parse a JSON HTTP response and log it. Hits STDHTTP + STDJSON + STDLOG end-to-end.",
      "steps": [
        {
          "action": "Scaffold",
          "command": "m new fetcher && cd fetcher",
          "n": 1
        },
        {
          "action": "Write tests/FETCHTST.m with STDASSERT + STDMOCK (mock STDHTTP)",
          "n": 2,
          "tools": [
            "module:m-stdlib#STDASSERT",
            "module:m-stdlib#STDMOCK"
          ]
        },
        {
          "action": "Implement src/fetch.m using STDHTTP for the call, STDJSON for parsing, STDLOG output",
          "n": 3,
          "tools": [
            "module:m-stdlib#STDHTTP",
            "module:m-stdlib#STDJSON",
            "module:m-stdlib#STDLOG"
          ]
        },
        {
          "action": "Run",
          "command": "m test && m fmt && m lint",
          "n": 4
        }
      ]
    },
    "tdd_inner_loop": {
      "description": "Canonical red → green → refactor loop using m-dev-tools. Mirrors `cargo new && cargo test && cargo clippy && cargo fmt` end to end.",
      "steps": [
        {
          "action": "Create a new M project with Makefile, .m-cli.toml, tests/, CI",
          "command": "m new myproj && cd myproj",
          "n": 1,
          "phase": "scaffold"
        },
        {
          "action": "Start the test engine container",
          "command": "make -C ~/m-dev-tools/m-test-engine up",
          "n": 2,
          "phase": "engine",
          "tool": "tool:m-test-engine"
        },
        {
          "action": "Write a failing test in tests/MYRTNTST.m using STDASSERT",
          "example": "do start^STDASSERT(.pass,.fail) ... do eq^STDASSERT(.pass,.fail,$$add^myrtn(2,3),5,\"add\") ... do report^STDASSERT(pass,fail)",
          "n": 3,
          "phase": "red",
          "tools": [
            "module:m-stdlib#STDASSERT"
          ]
        },
        {
          "action": "Run — confirm RED",
          "command": "m test",
          "n": 4,
          "phase": "red"
        },
        {
          "action": "Implement the routine until tests pass",
          "command": "m test",
          "n": 5,
          "phase": "green"
        },
        {
          "action": "Format + lint",
          "command": "m fmt && m lint --error-on=error",
          "n": 6,
          "phase": "refactor"
        },
        {
          "action": "Coverage gate (default ≥85%)",
          "command": "m coverage --min-percent=85",
          "n": 7,
          "phase": "gate"
        },
        {
          "action": "Optional — leave watch running for sub-second feedback",
          "command": "m watch",
          "n": 8,
          "note": "skip steps 4–6 manually after this; the watcher reruns affected suites on save",
          "phase": "watch"
        },
        {
          "action": "Pre-commit hook re-runs fmt-check + lint",
          "config": ".pre-commit-config.yaml referencing m-cli's .pre-commit-hooks.yaml",
          "n": 9,
          "phase": "commit",
          "tool": "tool:m-cli"
        },
        {
          "action": "Push — CI runs the same gates via `make ci`",
          "command": "git push",
          "n": 10,
          "phase": "ci",
          "see_also": [
            "cmd:m-cli#ci"
          ]
        }
      ]
    }
  }
